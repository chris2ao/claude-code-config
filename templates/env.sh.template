#!/bin/bash
# Environment variables for CJClaudin_Mac scripts
# Generated by install.sh - edit paths to match your machine

# ===== BASE DIRECTORIES =====
# Claude configuration directory (typically ~/.claude)
export CLAUDE_HOME="$HOME/.claude"

# Root directory where all AI projects live
export PROJECTS_DIR="YOUR_PROJECTS_DIR"

# ===== REPOSITORY PATHS =====
# Used by wrap-up, multi-repo-status, continuous-learning, and other automation scripts
# Adjust these to match your actual repository locations

# Main CJClaude application repository
export REPO_CJCLAUDE="$PROJECTS_DIR/CJClaude_1"

# Cryptoflex main site repository
export REPO_CRYPTOFLEX="$PROJECTS_DIR/cryptoflexllc"

# Cryptoflex operations/infrastructure repository
export REPO_OPS="$PROJECTS_DIR/cryptoflex-ops"

# Claude Code configuration repository (this repo)
export REPO_CONFIG="$CLAUDE_HOME"

# ===== TOOL PATHS =====
# On macOS with Homebrew, tools are automatically on PATH
# No manual PATH augmentation needed for node, npm, git, or gh
